#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

&mt { flavor = "tap-preferred"; };

/ {
    combos {
        compatible = "zmk,combos";

        capsword {
            bindings = <&caps_word>;
            key-positions = <4 7>;
        };

        vim_write {
            bindings = <&vim_write>;
            key-positions = <27 32>;
        };

        left_slide {
            bindings = <&kp LC(LEFT)>;
            key-positions = <25 30>;
        };

        right_slide {
            bindings = <&kp RC(RIGHT)>;
            key-positions = <34 29>;
        };
    };

    macros {
        vim_write: vim_write {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp COLON &kp W &kp ENTER>;
            label = "VIM_WRITE";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        impure_dvorak {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  Q  |  W  |  E  |  R  |  T  |   |  Y  |  U   |  I  |  O  |  P  | BSPC |
            // | CTRL |  A  |  S  |  D  |  F  |  G  |   |  H  |  J   |  K  |  L  |  ;  |  '   |
            // | SHFT |  Z  |  X  |  C  |  V  |  B  |   |  N  |  M   |  ,  |  .  |  /  | ESC  |
            //                    | GUI | LWR | SPC |   | ENT | RSE  | ALT |

            bindings = <
&none  &kp TAB         &kp COMMA           &lt 2 DOT         &kp L        &kp Y          &kp F        &kp G        &lt 2 C            &kp R                &kp P            &none
&none  &mt LEFT_ALT A  &mt LEFT_COMMAND O  &mt LEFT_SHIFT E  &kp I        &mt LCTRL U    &mt RCTRL D  &kp H        &mt RIGHT_SHIFT T  &mt RIGHT_COMMAND N  &mt RIGHT_ALT S  &none
&none  &kp SEMI        &kp Q               &kp J             &kp K        &kp X          &kp B        &mt LC(H) M  &kp W              &kp V                &kp Z            &none
                                           &to 0             &lt 1 SPACE  &mkp LCLK      &kp RET      &kp BSPC     &kp ESC
            >;
        };

        symbols {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  1  |  2  |  3  |  4  |  5  |   |  6  |  7  |  8  |  9  |  0  | BSPC |
            // | BTCLR| BT1 | BT2 | BT3 | BT4 | BT5 |   | LFT | DWN |  UP | RGT |     |      |
            // | SHFT |     |     |     |     |     |   |     |     |     |     |     |      |
            //                    | GUI |     | SPC |   | ENT |     | ALT |

            bindings = <
&none  &kp LEFT_BRACE        &kp PLUS     &kp UNDERSCORE  &kp DOUBLE_QUOTES  &kp BACKSLASH    &kp AT_SIGN    &kp TILDE        &kp UP_ARROW    &kp GRAVE     &kp RIGHT_BRACE        &none
&none  &kp LEFT_BRACKET      &kp EQUAL    &kp MINUS       &kp SINGLE_QUOTE   &kp SLASH        &kp POUND      &kp LEFT_ARROW   &kp DOWN_ARROW  &kp RIGHT     &kp RIGHT_BRACKET      &none
&none  &kp LEFT_PARENTHESIS  &kp PERCENT  &kp DOLLAR      &kp CARET          &kp PIPE         &kp AMPERSAND  &kp EXCLAMATION  &kp ASTERISK    &kp QUESTION  &kp RIGHT_PARENTHESIS  &none
                                          &trans          &trans             &trans           &trans         &trans           &trans
            >;
        };

        numpad {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  !  |  @  |  #  |  $  |  %  |   |  ^  |  &  |  *  |  (  |  )  | BSPC |
            // | CTRL |     |     |     |     |     |   |  -  |  =  |  [  |  ]  |  \  |  `   |
            // | SHFT |     |     |     |     |     |   |  _  |  +  |  {  |  }  | "|" |  ~   |
            //                    | GUI |     | SPC |   | ENT |     | ALT |

            bindings = <
&none  &kp EXCL  &kp AT            &kp HASH        &kp DLLR  &kp PRCNT    &kp MINUS  &kp N7  &kp N8  &kp N9  &none      &none
&none  &trans    &kp LEFT_COMMAND  &kp MINUS       &trans    &trans       &kp N0     &kp N1  &kp N2  &kp N3  &kp N0     &none
&none  &trans    &trans            &kp UNDERSCORE  &trans    &trans       &kp UNDER  &kp N4  &kp N5  &kp N6  &kp SLASH  &none
                                   &trans          &trans    &mkp RCLK    &trans     &trans  &trans
            >;
        };
    };
};
